  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=Jesser;Initial Catalog=EvaluacionDesempenoDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>d25e3964-892d-4e61-bea0-fda94265b4b5</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@EstadoPlan">
            <Value>=Parameters!EstadoPlan.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    S.nombreSucursal,
    (E.Nombres + ' ' + E.Apellidos) AS NombreEmpleado,
    C.nombreCargo,
    PM.Actividades,
    PM.FechaInicio,
    PM.FechaFin,
    PM.Estado AS EstadoPlan,
    ISNULL(Seg.EstadoCompromiso, 'Sin Seguimiento') AS EstadoCompromiso,
    ISNULL(Seg.Evidencias, 'Ninguna') AS Evidencias,
    Seg.FechaSeguimiento
FROM Desarrollo.PlanMejora PM
INNER JOIN Organizacion.Empleado E ON PM.ID_Empleado = E.ID_Empleado
INNER JOIN Organizacion.Cargo C ON E.ID_Cargo = C.cargoID
INNER JOIN Organizacion.Departamento D ON C.departamentoID = D.departamentoID
INNER JOIN Organizacion.Sucursal S ON D.sucursalID = S.sucursalID
LEFT JOIN Desarrollo.Seguimiento Seg ON PM.ID_PMI = Seg.ID_PMI
WHERE PM.Estado = @EstadoPlan OR @EstadoPlan = 'Todos';</CommandText>
      </Query>
      <Fields>
        <Field Name="nombreSucursal">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreSucursal</DataField>
        </Field>
        <Field Name="NombreEmpleado">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>NombreEmpleado</DataField>
        </Field>
        <Field Name="nombreCargo">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreCargo</DataField>
        </Field>
        <Field Name="Actividades">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Actividades</DataField>
        </Field>
        <Field Name="FechaInicio">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>FechaInicio</DataField>
        </Field>
        <Field Name="FechaFin">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>FechaFin</DataField>
        </Field>
        <Field Name="EstadoPlan">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EstadoPlan</DataField>
        </Field>
        <Field Name="EstadoCompromiso">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>EstadoCompromiso</DataField>
        </Field>
        <Field Name="Evidencias">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Evidencias</DataField>
        </Field>
        <Field Name="FechaSeguimiento">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>FechaSeguimiento</DataField>
        </Field>
      </Fields>
    </DataSet>
