  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=Jesser;Initial Catalog=EvaluacionDesempenoDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>765e8269-98f7-4881-bab0-532c58238e11</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_Periodo">
            <Value>=Parameters!ID_Periodo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    SF.cuadrante9Box,
    S.nombreSucursal,
    D.nombreDepartamento,
    (E.Nombres + ' ' + E.Apellidos) AS NombreEmpleado,
    C.nombreCargo,
    SF.scoreTotal
FROM Analisis.ScoreFinal SF
INNER JOIN Organizacion.Empleado E ON SF.ID_Empleado = E.ID_Empleado
INNER JOIN Organizacion.Cargo C ON E.ID_Cargo = C.cargoID
INNER JOIN Organizacion.Departamento D ON C.departamentoID = D.departamentoID
INNER JOIN Organizacion.Sucursal S ON D.sucursalID = S.sucursalID
WHERE SF.ID_Periodo = @ID_Periodo;</CommandText>
      </Query>
      <Fields>
        <Field Name="cuadrante9Box">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>cuadrante9Box</DataField>
        </Field>
        <Field Name="nombreSucursal">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreSucursal</DataField>
        </Field>
        <Field Name="nombreDepartamento">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreDepartamento</DataField>
        </Field>
        <Field Name="NombreEmpleado">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>NombreEmpleado</DataField>
        </Field>
        <Field Name="nombreCargo">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreCargo</DataField>
        </Field>
        <Field Name="scoreTotal">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>scoreTotal</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
