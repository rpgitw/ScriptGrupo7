  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=Jesser;Initial Catalog=EvaluacionDesempenoDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>b39c47b5-2765-4230-b541-a4939eb5674a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_Periodo">
            <Value>=Parameters!ID_Periodo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TipoCompetencia">
            <Value>=Parameters!TipoCompetencia.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    D.nombreDepartamento,
    Comp.NombreCompetencia,
    Comp.TipoCompetencia,
    Comp.Categoria,
    AVG(CAST(BC.nivelRequerido AS DECIMAL(5,2))) AS RequeridoPromedio,
    AVG(CAST(BC.nivelObtenido AS DECIMAL(5,2))) AS ObtenidoPromedio,
    AVG(CAST(BC.brecha AS DECIMAL(5,2))) AS BrechaPromedio
FROM Analisis.BrechaCompetencia BC
INNER JOIN Competencias.Competencia Comp ON BC.ID_Competencia = Comp.ID_Competencia
INNER JOIN Desempeno.Evaluacion Ev ON BC.ID_Evaluacion = Ev.ID_Evaluacion
INNER JOIN Organizacion.Empleado E ON Ev.ID_Empleado = E.ID_Empleado
INNER JOIN Organizacion.Cargo C ON E.ID_Cargo = C.cargoID
INNER JOIN Organizacion.Departamento D ON C.departamentoID = D.departamentoID
WHERE Ev.ID_Periodo = @ID_Periodo 
  AND (Comp.TipoCompetencia = @TipoCompetencia OR @TipoCompetencia = 'Todos')
GROUP BY D.nombreDepartamento, Comp.NombreCompetencia, Comp.TipoCompetencia, Comp.Categoria;</CommandText>
      </Query>
      <Fields>
        <Field Name="nombreDepartamento">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nombreDepartamento</DataField>
        </Field>
        <Field Name="NombreCompetencia">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>NombreCompetencia</DataField>
        </Field>
        <Field Name="TipoCompetencia">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TipoCompetencia</DataField>
        </Field>
        <Field Name="Categoria">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Categoria</DataField>
        </Field>
        <Field Name="RequeridoPromedio">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>RequeridoPromedio</DataField>
        </Field>
        <Field Name="ObtenidoPromedio">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ObtenidoPromedio</DataField>
        </Field>
        <Field Name="BrechaPromedio">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>BrechaPromedio</DataField>
        </Field>
      </Fields>
    </DataSet>
