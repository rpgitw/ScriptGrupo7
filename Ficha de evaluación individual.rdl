  <DataSources>
    <DataSource Name="DataSource1">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=Jesser;Initial Catalog=EvaluacionDesempenoDB</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>725abcfe-97a3-4dec-801d-b1ba7f432691</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DSFicha">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ID_Periodo">
            <Value>=Parameters!ID_Periodo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ID_Empleado">
            <Value>=Parameters!ID_Empleado.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    E.ID_Empleado,
    (E.Nombres + ' ' + E.Apellidos) AS NombreEmpleado,
    C.nombreCargo,
    D.nombreDepartamento,
    S.nombreSucursal,
    P.NombrePeriodo,
    SF.scoreCompetencias,
    SF.scoreMetas,
    SF.scoreTotal,
    SF.cuadrante9Box,
    F.Comentarios,
    F.Fortalezas,
    F.OportunidadesMejora
FROM Organizacion.Empleado E
INNER JOIN Organizacion.Cargo C ON E.ID_Cargo = C.cargoID
INNER JOIN Organizacion.Departamento D ON C.departamentoID = D.departamentoID
INNER JOIN Organizacion.Sucursal S ON D.sucursalID = S.sucursalID
INNER JOIN Analisis.ScoreFinal SF ON E.ID_Empleado = SF.ID_Empleado
INNER JOIN Desempeno.PeriodoEvaluativo P ON SF.ID_Periodo = P.ID_Periodo
LEFT JOIN Desempeno.Evaluacion Ev ON E.ID_Empleado = Ev.ID_Empleado AND Ev.ID_Periodo = P.ID_Periodo
LEFT JOIN Desempeno.Feedback F ON Ev.ID_Evaluacion = F.ID_Evaluacion
WHERE SF.ID_Periodo = @ID_Periodo AND E.ID_Empleado = @ID_Empleado;</CommandText>
      </Query>
